# ── MJRH V2 — Environment Variables ──
# Copy this file to .env and fill in your values.
# In Vercel: add these in Project → Settings → Environment Variables

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY_HERE
# Backward-compatible alternative used by some Supabase projects:
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY_HERE
