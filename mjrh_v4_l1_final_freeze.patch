-+    lifecycle_status text NOT NULL DEFAULT 'DRAFT' CHECK (lifecycle_status IN ('DRAFT', 'ACTIVE', 'SUSPENDED', 'ARCHIVED')),
-+    node_path ltree,
-+    UNIQUE(id, identity_id) -- Identity constraint helper
