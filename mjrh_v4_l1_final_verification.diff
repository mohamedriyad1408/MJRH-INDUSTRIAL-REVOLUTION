 $$ LANGUAGE plpgsql;
 
--- [LOGIC] Subtree Propagation
+-- [LOGIC: Subtree Propagation with Recursive Guard]
 CREATE OR REPLACE FUNCTION v4_l1.fn_l1_propagation() RETURNS trigger AS $$
 BEGIN
+    IF (pg_trigger_depth() > 1) THEN RETURN NEW; END IF;
