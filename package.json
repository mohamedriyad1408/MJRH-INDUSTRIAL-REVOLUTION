{
  "name": "mjrh-v2",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest tests",
    "test:run": "vitest run --passWithNoTests",
    "coverage": "vitest run tests --coverage",
    "ci": "npm run typecheck && npm run test:run && npm run e2e && npm run build",
    "audit:ci": "npm audit --audit-level=moderate",
    "e2e": "playwright test",
    "e2e:public": "playwright test e2e/public-smoke.spec.ts e2e/mobile-regression.spec.ts",
    "e2e:i18n": "playwright test e2e/authenticated-i18n.spec.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:auth": "playwright test e2e/authenticated-smoke.spec.ts",
    "e2e:auth:all": "playwright test e2e/authenticated-smoke.spec.ts e2e/authenticated-i18n.spec.ts",
    "verify:new-tenant": "node scripts/verify-new-tenant-readiness.mjs",
    "ci:full": "npm run repo:guard && npm run audit:ci && npm run typecheck && npm run test:run && npm run e2e && npm run verify:new-tenant && npm run build && npm run bundle:check",
    "repo:guard": "node scripts/repo-guard.mjs",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "prod:health": "node scripts/check-production-health.mjs",
    "demo:dry-run": "node scripts/seed-demo-tenant.mjs",
    "demo:seed": "DEMO_APPLY=1 node scripts/seed-demo-tenant.mjs"
  },
