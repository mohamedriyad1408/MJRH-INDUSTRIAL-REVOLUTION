    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
